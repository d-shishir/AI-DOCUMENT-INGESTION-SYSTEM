# Database Connection (Defaults to the local-postgres Docker container on port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/doc_ingest

# API Key (Your OpenAI key OR OpenRouter key)
OPENAI_API_KEY=your_openai_or_openrouter_api_key_here

# API Base URL (Change to OpenRouter URL if using OpenRouter, defaults to standard OpenAI endpoint)
# OpenAI default: https://api.openai.com/v1
# OpenRouter URL: https://openrouter.ai/api/v1
OPENAI_API_BASE=https://api.openai.com/v1

# LLM Model Identifier (For chat, reasoning, and extraction)
# OpenAI default: gpt-4o-mini
# OpenRouter free models: google/gemini-2.5-flash:free OR meta-llama/llama-3-8b-instruct:free
OPENAI_MODEL=gpt-4o-mini

# Text Embedding Model Identifier (For chunk vectorization - Must generate 1536-dimensional vectors)
# OpenAI default: text-embedding-3-small
# OpenRouter route: text-embedding-3-small (automatically prefixed if routed via OpenRouter)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

